@model NCS_TEST.Models.MainMenuModel

@{
    ViewBag.Title = "メインメニュー";
}

<style>
    body {
        font-family: Meiryo;
        margin: 20px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .menu-area {
        text-align: center;
        margin-top: 50px;
    }

    .menu-button {
        width: 250px;
        height: 50px;
        margin: 10px;
        font-size: 16px;
    }
</style>

<div class="header">
    <div>
        <h3>NWカメラ安全管理システム</h3>
    </div>

    <div>
        ログインユーザ：@Model.Form.UserName

        <button>
            ログアウト
        </button>
    </div>
</div>

<hr />

<div class="menu-area">

    <h2>メインメニュー</h2>

    <button class="menu-button">
        工事一覧
    </button>

    <br />

    <button class="menu-button">
        カメラ一覧
    </button>

    <br />

    <button class="menu-button"
            @(Model.Form.MaintenanceEnabled ? "" : "disabled")>
        メンテナンスメニュー
    </button>

</div>